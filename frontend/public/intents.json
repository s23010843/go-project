{
  "intents": [
    {
      "name": "greeting",
      "patterns": ["^(hi|hello|hey|hiya|howdy|good\\s*(morning|afternoon|evening)|greetings?)\\b"],
      "responses": [
        "Hello! 👋 Ask me about any crop price — e.g. 'Wheat in Central Wholesale Market' or 'Rice price today'.",
        "Hi there! I can help find current market prices for many crops. What would you like to check?"
      ]
    },
    {
      "name": "thanks",
      "patterns": ["\\b(thanks?|thank you|thx|ty)\\b"],
      "responses": ["You're welcome! 😊 Ask anytime.", "Happy to help! Anything else?"]
    },
    {
      "name": "goodbye",
      "patterns": ["\\b(bye|goodbye|see\\s*you|later|cya)\\b"],
      "responses": ["Goodbye! Come back for fresh prices.", "See you! Stay safe."]
    },
    {
      "name": "about",
      "patterns": ["\\b(who are you|what are you|your name|about you)\\b"],
      "responses": ["I'm the Farm Price Assistant 🌾 — I provide real-time market prices (when available) and guidance for crops and markets."]
    },
    {
      "name": "help",
      "patterns": ["\\b(help|what can you do|how.*work|commands?)\\b"],
      "responses": [
        "I can look up crop prices and list supported crops and markets. Try: 'Price of Potato in Northern Regional Market' or 'List crops'."
      ]
    },
    {
      "name": "list_crops",
      "patterns": ["\\b(what crops?|which crops?|available crops?|list crops?)\\b"],
      "responses": ["{{data.crops}}"],
      "note": "At runtime replace {{data.crops}} with the joined `data.crops` (e.g. `data.crops.join(', ')`)."
    },
    {
      "name": "list_markets",
      "patterns": ["\\b(what markets?|which markets?|available markets?|list markets?|markets?)\\b"],
      "responses": ["{{data.markets}}"],
      "note": "At runtime replace {{data.markets}} with the joined `data.markets` (e.g. `data.markets.join(', ')`)."
    },
    {
      "name": "price_query_help",
      "patterns": [
        "\\b(how\\s*(do\\s*i|can\\s*i|to)\\s.*price|how to ask.*price|example.*price|show me an example.*price)\\b"
      ],
      "responses": [
        "To get a price, ask like: 'Price of <crop> in <market>' or 'What's the price of <crop> today?'.",
        "Specify a market for more accurate results: e.g. 'Tomato in Southern Produce Exchange'."
      ],
      "note": "This intent is a help/template responder. The app should extract crop and market from user text using `data.crops` and `data.markets` programmatically; avoid using this intent to answer normal price queries."
    },
    {
      "name": "fallback",
      "patterns": [".*"],
      "responses": [
        "Sorry, I didn't get that. Ask for a crop price (e.g. 'Wheat in Eastern Grain Hub') or 'List crops'."
      ]
    }
  ],
