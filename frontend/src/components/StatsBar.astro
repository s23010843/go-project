---
// No props needed — JS updates these by ID
---
<section class="stats-bar" id="statsBar" aria-label="Summary statistics" hidden>
  <div class="stat-item">
    <span class="stat-value" id="statCrops">—</span>
    <span class="stat-label">Crops</span>
  </div>
  <div class="stat-item">
    <span class="stat-value" id="statMarkets">—</span>
    <span class="stat-label">Markets</span>
  </div>
  <div class="stat-item">
    <span class="stat-value" id="statAvg">—</span>
    <span class="stat-label">Avg Price</span>
  </div>
  <div class="stat-item">
    <span class="stat-value" id="statHigh">—</span>
    <span class="stat-label">Highest</span>
  </div>
  <div class="stat-item">
    <span class="stat-value" id="statLow">—</span>
    <span class="stat-label">Lowest</span>
  </div>
</section>
