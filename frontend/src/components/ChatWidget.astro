---
import BotSvg from './BotSvg.astro';
---
<!-- Floating Chat Button -->
<button class="chat-fab" id="chatFab" aria-label="Open chat assistant" aria-expanded="false" aria-controls="chatWidget">
  <span class="fab-icon fab-icon--bot">
    <BotSvg idPrefix="bot-fab" size={38} />
  </span>
  <span class="fab-icon fab-icon--close" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </span>
</button>

<!-- Chat Widget Panel -->
<aside class="chat-widget" id="chatWidget" role="dialog" aria-labelledby="chatTitle" aria-hidden="true" tabindex="-1">

  <div class="chat-widget-header">
    <div class="chat-widget-title">
      <span class="chat-header-icon">
        <BotSvg idPrefix="bot-hdr" size={28} />
      </span>
      <span id="chatTitle">FarmBot Assistant</span>
    </div>
    <button class="chat-close-btn" id="chatClose" aria-label="Close chat">
      <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
  <div class="chat-window" id="chatWindow" role="log" aria-live="polite" aria-label="Chat messages"></div>
  <div class="chat-input-row">
    <label for="chatInput" class="sr-only">Message FarmBot</label>
    <input type="text" id="chatInput" placeholder="Ask about prices, crops…" autocomplete="off" aria-label="Message input" />
    <button id="chatSend" aria-label="Send message">
      <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"/>
        <polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
    </button>
  </div>
</aside>

<script>
function initEyeTracking(prefix, maxR = 2.2) {
  const pupilL = document.getElementById(`${prefix}-pupil-l`);
  const pupilR = document.getElementById(`${prefix}-pupil-r`);
  const glintL = document.getElementById(`${prefix}-glint-l`);
  const glintR = document.getElementById(`${prefix}-glint-r`);
  if (!pupilL || !pupilR) return;

  const getSvgEl = () => pupilL.closest('svg');

  const BASE = { lx: 23, ly: 35, rx: 41, ry: 35, glx: 24.5, gly: 33, grx: 42.5, gry: 33 };

  function move(e) {
    const svg = getSvgEl(); if (!svg) return;
    const rect = svg.getBoundingClientRect();
    const cx = rect.left + rect.width / 2;
    const cy = rect.top + rect.height / 2;
    let px, py;
    if (e && 'touches' in e && e.touches && e.touches.length) {
      px = e.touches[0].clientX;
      py = e.touches[0].clientY;
    } else {
      px = e.clientX;
      py = e.clientY;
    }
    const angle = Math.atan2(py - cy, px - cx);
    const cos = Math.cos(angle), sin = Math.sin(angle);

    pupilL.setAttribute('cx', String(BASE.lx + cos * maxR));
    pupilL.setAttribute('cy', String(BASE.ly + sin * maxR));
    pupilR.setAttribute('cx', String(BASE.rx + cos * maxR));
    pupilR.setAttribute('cy', String(BASE.ry + sin * maxR));
    if (glintL) { glintL.setAttribute('cx', String(BASE.glx + cos * maxR)); glintL.setAttribute('cy', String(BASE.gly + sin * maxR)); }
    if (glintR) { glintR.setAttribute('cx', String(BASE.grx + cos * maxR)); glintR.setAttribute('cy', String(BASE.gry + sin * maxR)); }
  }

  window.addEventListener('mousemove', move, { passive: true });
  window.addEventListener('touchmove', move, { passive: true });
}

initEyeTracking('bot-fab');
initEyeTracking('bot-hdr');

// Chat widget
const fab = document.getElementById('chatFab');
const widget = document.getElementById('chatWidget');
const closeBtn = document.getElementById('chatClose');
const chatWindow = document.getElementById('chatWindow');
const chatInput = document.getElementById('chatInput');
const chatSend = document.getElementById('chatSend');

let intents = [];
let botData = {};
let botPrices = null;
if (!fab || !widget || !closeBtn || !chatWindow || !chatInput || !chatSend) {
  console.warn('ChatWidget: missing DOM elements, chat initialization skipped.');
} else {
  const $fab = fab;
  const $widget = widget;
  const $closeBtn = closeBtn;
  const $chatWindow = chatWindow;
  const $chatInput = chatInput;
  const $chatSend = chatSend;

  loadIntents();

  async function loadIntents() {
    try {
      const [resIntents, resPrices] = await Promise.all([fetch('/intents.json'), fetch('/prices.json').catch(()=>null)]);
      const data = resIntents ? await resIntents.json() : {};
      const raw = Array.isArray(data) ? data : (data.intents || []);
      const dataObj = (data && data.data) ? data.data : {};
      botData = dataObj;

      if (resPrices) {
        try { botPrices = await resPrices.json(); } catch(e) { botPrices = null; }
      }

      intents = raw.map(function(it) {
        const srcResponses = it.replies || it.responses || [];
        const responses = (srcResponses || []).map(function(r) {
          if (typeof r !== 'string') return r;
          return r
            .replace(/\{\{\s*data\.crops\s*\}\}/gi, (Array.isArray(dataObj.crops) ? dataObj.crops.join(', ') : ''))
            .replace(/\{\{\s*data\.markets\s*\}\}/gi, (Array.isArray(dataObj.markets) ? dataObj.markets.join(', ') : ''));
        });
        return { patterns: it.patterns || [], responses: responses };
      });
    } catch (e) { /* silent */ }
  }

  function normalizeText(s) {
    return String(s || '').toLowerCase().replace(/[\u2018\u2019\u201C\u201D]/g, "'").replace(/["'.,()\[\]{}\/\\]/g,'').trim();
  }

  function levenshtein(a, b) {
    a = String(a||''); b = String(b||''); if (a === b) return 0; if (!a.length) return b.length; if (!b.length) return a.length;
    let v0 = Array(b.length + 1), v1 = Array(b.length + 1);
    for (let i = 0; i <= b.length; i++) v0[i] = i;
    for (let i = 0; i < a.length; i++) {
      v1[0] = i + 1;
      for (let j = 0; j < b.length; j++) {
        const cost = a[i] === b[j] ? 0 : 1;
        v1[j+1] = Math.min(v1[j] + 1, v0[j+1] + 1, v0[j] + cost);
      }
      for (let j = 0; j <= b.length; j++) v0[j] = v1[j];
    }
    return v1[b.length];
  }

  function findBestMatch(query, list) {
    if (!query || !Array.isArray(list) || !list.length) return null;
    const nq = normalizeText(query);
    let best = {item: null, score: Infinity};
    for (let i = 0; i < list.length; i++) {
      const item = list[i];
      const ni = normalizeText(item);
      if (ni === nq) return item;
      if (ni.indexOf(nq) !== -1 || nq.indexOf(ni) !== -1) return item;
      const d = levenshtein(nq, ni);
      if (d < best.score) best = {item: item, score: d};
    }
    // allow small edits proportional to length
    if (best.item && best.score <= Math.max(1, Math.floor(normalizeText(best.item).length * 0.25))) return best.item;
    return null;
  }

  function findCropInText(q) {
    if (!botData || !Array.isArray(botData.crops)) return null;
    // try direct find first
    for (let i = 0; i < botData.crops.length; i++) {
      const name = botData.crops[i];
      const re = new RegExp('\\b' + name.replace(/[.*+?^${}()|[\]\\]/g,'\\$&') + '\\b','i');
      if (re.test(q)) return name;
    }
    // fuzzy
    const words = q.split(/\s+/).filter(Boolean);
    for (let w of words) {
      const fm = findBestMatch(w, botData.crops);
      if (fm) return fm;
    }
    return findBestMatch(q, botData.crops);
  }

  function findMarketInText(q) {
    if (!botData || !Array.isArray(botData.markets)) return null;
    for (let i = 0; i < botData.markets.length; i++) {
      const name = botData.markets[i];
      const re = new RegExp('\\b' + name.replace(/[.*+?^${}()|[\]\\]/g,'\\$&') + '\\b','i');
      if (re.test(q)) return name;
    }
    return findBestMatch(q, botData.markets);
  }

  function lookupPrice(crop, market) {
    if (!botPrices || !botPrices.markets) return null;
    const m = botPrices.markets.find(x => normalizeText(x.name) === normalizeText(market)) || botPrices.markets.find(x => normalizeText(x.name).indexOf(normalizeText(market))!==-1) || null;
    if (!m) return null;
    // try direct commodity key
    const commodities = m.commodities || {};
    if (commodities[crop]) return {market: m, commodity: commodities[crop], key: crop};
    // try best match among commodity keys
    const keys = Object.keys(commodities);
    const bestKey = findBestMatch(crop, keys);
    if (bestKey) return {market: m, commodity: commodities[bestKey], key: bestKey};
    return null;
  }

  function getFocusable(container) {
    const selector = 'a[href], area[href], input:not([disabled]), select:not([disabled]), textarea:not([disabled]), button:not([disabled]), [tabindex]:not([tabindex="-1"])';
    return Array.from(container.querySelectorAll(selector)).filter(function(el) {
      try { return el.offsetParent !== null; } catch (e) { return true; }
    });
  }

  let _widgetKeyHandler = null;
  function enableFocusTrap() {
    if (_widgetKeyHandler) return;
    _widgetKeyHandler = function(e) {
      if (e.key !== 'Tab') return;
      const focusable = getFocusable($widget);
      if (!focusable.length) { e.preventDefault(); return; }
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
      else if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
    };
    $widget.addEventListener('keydown', _widgetKeyHandler);
  }
  function disableFocusTrap() {
    if (!_widgetKeyHandler) return;
    $widget.removeEventListener('keydown', _widgetKeyHandler);
    _widgetKeyHandler = null;
  }

  let prevFocus = null;
  function openChat() {
    prevFocus = document.activeElement;
    $widget.setAttribute('aria-hidden','false');
    $fab.setAttribute('aria-expanded','true');
    $widget.setAttribute('aria-modal','true');
    $widget.removeAttribute('tabindex');
    enableFocusTrap();
    if (!$chatWindow.childElementCount) addBotMsg('👋 Hi! Ask me about crop prices, markets, or use the tools above.');
    setTimeout(function(){ try { $chatInput.focus(); } catch (e) {} }, 220);
  }
  function closeChat() {
    $widget.setAttribute('aria-hidden','true');
    $fab.setAttribute('aria-expanded','false');
    $widget.removeAttribute('aria-modal');
    $widget.setAttribute('tabindex','-1');
    disableFocusTrap();
    if (prevFocus && prevFocus.focus) prevFocus.focus();
  }
  function toggleChat(open) {
    var next = (open !== undefined) ? open : !$fab.classList.contains('is-open');
    $fab.classList.toggle('is-open', next);
    $widget.classList.toggle('is-open', next);
    $fab.setAttribute('aria-expanded', String(next));
    $widget.setAttribute('aria-hidden', String(!next));
    if (next) {
      $widget.setAttribute('aria-modal', 'true');
      $widget.removeAttribute('tabindex');
      enableFocusTrap();
      if (!$chatWindow.childElementCount) addBotMsg('👋 Hi! Ask me about crop prices, markets, or use the tools above.');
      setTimeout(function(){ try { $chatInput.focus(); } catch (e) {} }, 220);
    } else {
      $widget.removeAttribute('aria-modal');
      $widget.setAttribute('tabindex','-1');
      disableFocusTrap();
      try { $fab.focus(); } catch (e) {}
    }
  }

  $fab.addEventListener('click', function(){ toggleChat(); });
  $closeBtn.addEventListener('click', function(){ toggleChat(false); });
  document.addEventListener('keydown', function(e){ if (e.key === 'Escape') toggleChat(false); });

  $chatSend.addEventListener('click', sendMsg);
  $chatInput.addEventListener('keydown', function(e){ if (e.key === 'Enter') sendMsg(); });

  function addMsg(text, who) {
    const container = document.createElement('div');
    container.className = 'chat-message ' + who;

    const msg = document.createElement('div');
    msg.className = 'chat-message__text';
    msg.textContent = text;

    const copyBtn = document.createElement('button');
    copyBtn.type = 'button';
    copyBtn.className = 'chat-copy-btn';
    copyBtn.setAttribute('aria-label', 'Copy message');
    copyBtn.title = 'Copy message';
    // clipboard SVG (no visible text)
    copyBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 4h-1.5a2 2 0 0 0-3.9 0H9a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h7a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2z"></path><path d="M9 8h6"></path></svg>';
    copyBtn.addEventListener('click', function(e) { e.stopPropagation(); copyToClipboard(text, copyBtn); });

    container.appendChild(msg);
    container.appendChild(copyBtn);
    $chatWindow.appendChild(container);
    $chatWindow.scrollTop = $chatWindow.scrollHeight;
  }
  function addBotMsg(text) { addMsg(text, 'bot'); }
  function addUserMsg(text) { addMsg(text, 'user'); }

  function copyToClipboard(text, btn) {
    if (!btn) return;
    const originalHTML = btn.innerHTML;
    const checkSVG = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>';
    function flash() {
      btn.innerHTML = checkSVG;
      btn.setAttribute('aria-pressed','true');
      setTimeout(function(){ btn.innerHTML = originalHTML; btn.removeAttribute('aria-pressed'); }, 1400);
    }
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text).then(flash).catch(function(){
        try {
          const ta = document.createElement('textarea'); ta.value = text; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); ta.remove(); flash();
        } catch (e) { /* ignore */ }
      });
    } else {
      try {
        const ta = document.createElement('textarea'); ta.value = text; document.body.appendChild(ta); ta.select(); document.execCommand('copy'); ta.remove(); flash();
      } catch (e) { /* ignore */ }
    }
  }

  function sendMsg() {
    const raw = $chatInput.value.trim(); if (!raw) return;
    addUserMsg(raw);
    $chatInput.value = '';
    const reply = getReply(raw.toLowerCase());
    setTimeout(function(){ addBotMsg(reply); }, 320);
  }

  function getReply(q) {
    const defaultReply = "I'm not sure about that. Try asking about crop prices, markets, or how to download data!";
    function escapeRe(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }
    try {
      // Check for colors/varieties questions first
      const wantsVarieties = /\b(variet(?:y|ies)|which varieties|what varieties|varieties of)\b/i.test(q);
      const wantsColors = /\b(colou?r|colors?)\b/i.test(q) && /\b(color of|colors of|what color|what colors|colors?)?\b/i.test(q);
      const cropMention = findCropInText(q);
      if (wantsVarieties) {
        if (cropMention && botData.varieties && botData.varieties[cropMention]) {
          return `${cropMention} varieties: ${botData.varieties[cropMention].join(', ')}.`;
        }
        if (cropMention) return `No variety data available for ${cropMention}.`;
        return `Which crop do you want varieties for?`;
      }
      if (wantsColors) {
        if (cropMention && botData.colors && botData.colors[cropMention]) {
          return `${cropMention} colors: ${botData.colors[cropMention].join(', ')}.`;
        }
        if (cropMention) return `No color data available for ${cropMention}.`;
        return `Which crop do you mean? For example: 'Colors of Tomato' or 'What colors are apples?'.`;
      }

      // Try to find crop and market (with fuzzy matching)
      const foundCrop = findCropInText(q);
      const foundMarket = findMarketInText(q);
      if (foundCrop && foundMarket) {
        const p = lookupPrice(foundCrop, foundMarket);
        if (p && p.commodity) {
          const cur = (botPrices && botPrices.currency) ? botPrices.currency : '';
          const u = p.commodity.unit || '';
          return `Price for ${foundCrop} in ${p.market.name}: ${cur}${p.commodity.price} per ${u} (low: ${cur}${p.commodity.low}, high: ${cur}${p.commodity.high}).`;
        }
        return `No price data found for ${foundCrop} in ${foundMarket}.`;
      }
      if (foundCrop && !foundMarket) {
        // show markets where crop is available if possible
        if (botPrices && botPrices.markets) {
          const avail = botPrices.markets.filter(function(m){
            const keys = Object.keys(m.commodities || {});
            return !!findBestMatch(foundCrop, keys);
          }).map(function(m){ return m.name; });
          if (avail.length) return `Specify a market for ${foundCrop}. Available in: ${avail.join(', ')}.`;
        }
        return `Specify a market for ${foundCrop} for more accurate results: e.g. 'Price of ${foundCrop} in Northern Regional Market'.`;
      }
      if (!foundCrop && foundMarket) {
        return `Which crop do you want the price for in ${foundMarket}?`;
      }
      // fallthrough to intent patterns below
    } catch (e) { /* ignore extraction errors */ }
    for (let i = 0; i < intents.length; i++) {
      const intent = intents[i];
      const pats = intent.patterns || [];
      for (let j = 0; j < pats.length; j++) {
        const pattern = pats[j];
        try {
          const re = new RegExp(pattern, 'i');
          if (re.test(q)) {
            const responses = intent.responses || [];
            return responses[Math.floor(Math.random() * responses.length)] || defaultReply;
          }
        } catch (e) {
          if (typeof pattern === 'string' && q.includes(pattern.toLowerCase())) {
            const responses = intent.responses || [];
            return responses[Math.floor(Math.random() * responses.length)] || defaultReply;
          }
        }
      }
    }
    return defaultReply;
  }
}
</script>
