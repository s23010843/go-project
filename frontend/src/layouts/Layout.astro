---
import '../styles/global.css';
export interface Props {
  title?: string;
  description?: string;
  page?: string;
}
const { title = 'Farm Market Prices', description = 'Real-time farm market price comparison across India.', page = '' } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <!-- Favicon -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <!-- PWA / Manifest -->
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#2e7d32" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="FarmPrices" />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  
</head>
<body class={page ? `page-${page}` : ''}>
  <a href="#main-content" class="skip-link">Skip to main content</a>

  <slot />

  <!-- Footer -->
  <footer class="site-footer" role="contentinfo" aria-label="Site footer">
    <div class="footer-inner">
      <span>🌾 Farm Market Price Portal</span>
      <span class="footer-sep" aria-hidden="true">&nbsp;|&nbsp;</span>
      <span>Data updated daily</span>
      <span class="footer-sep" aria-hidden="true">&nbsp;|&nbsp;</span>
      <span>Made with ❤️ for farmers</span>
    </div>
  </footer>

  <!-- SW Registration -->
  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/sw.js').catch(() => {});
      });
    }
  </script>

  <script>
    // Respect users' reduced-motion preference: pause/hide background videos
    try {
      const mq = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)');
      if (mq && mq.matches) {
        const vids = document.querySelectorAll('video.bg-video, video#bg-video, .offline-bg video');
        vids.forEach(v => {
          try {
            // Pause playback, remove autoplay, hide visually and from assistive tech
            (v as HTMLVideoElement).pause();
            v.removeAttribute('autoplay');
            v.style.display = 'none';
            v.setAttribute('aria-hidden', 'true');
          } catch (e) {}
        });
      }
    } catch (e) { /* noop */ }
  </script>

  <!-- Minimal toast helper (pages may provide #toastContainer; create if missing) -->
  <script>
    function _getToastContainer(): HTMLElement {
      let c = document.getElementById('toastContainer') as HTMLElement | null;
      if (!c) {
        c = document.createElement('div');
        c.id = 'toastContainer';
        c.className = 'toast-container';
        c.setAttribute('role','status');
        c.setAttribute('aria-live','polite');
        c.setAttribute('aria-atomic','true');
        document.body.appendChild(c);
      }
      return c;
    }

    function createToast(msg: string, type: 'info' | 'success' | 'error' = 'info', duration = 3200): void {
      const container = _getToastContainer();
      const t = document.createElement('div');
      t.className = `toast ${type}`;
      // Use assertive announcements for errors, polite otherwise
      if (type === 'error') {
        t.setAttribute('role', 'alert');
        t.setAttribute('aria-live', 'assertive');
      } else {
        t.setAttribute('role', 'status');
        t.setAttribute('aria-live', 'polite');
      }
      t.textContent = msg;
      container.appendChild(t);
      setTimeout(() => {
        t.classList.add('removing');
        t.addEventListener('animationend', () => t.remove(), { once: true });
      }, duration);
    }
  </script>
</body>
</html>
