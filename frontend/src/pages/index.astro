---
import Layout from '../layouts/Layout.astro';
import StatsBar from '../components/StatsBar.astro';
import ChatWidget from '../components/ChatWidget.astro';
---
<Layout title="Farm Market Prices" description="Compare farm-fresh produce prices across markets in India." page="index">

  <!-- Background video (hidden from assistive tech) -->
  <div class="bg-video-wrap" aria-hidden="true">
    <video class="bg-video" autoplay muted loop playsinline preload="auto" poster="/assets/videos/agriculture-environment.mp4">
      <source src="/assets/videos/agriculture-environment.mp4" type="video/mp4" />
      <!-- fallback text left intentionally empty for screen readers -->
    </video>
    <div class="bg-video-overlay" aria-hidden="true"></div>
  </div>

  <!-- Toast container -->
  <div class="toast-container" id="toastContainer" role="status" aria-live="polite" aria-atomic="false"></div>

  <!-- Header -->
  <header>
    <div class="header-badge" aria-label="Live data">
      <span class="badge-dot" aria-hidden="true"></span> Live Data
    </div>
    <h1>🌾 Farm Market Prices</h1>
    <p>Compare fresh produce prices across markets — download, filter, and plan ahead.</p>
    <button id="installBtn" class="install-btn" hidden aria-label="Install app">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Install App
    </button>
  </header>

  <!-- Stats bar -->
  <StatsBar />

  <main id="main-content">
    <div class="page-wrapper">

      <!-- Filters card -->
      <section class="card" aria-labelledby="filters-title">
        <h2 class="card-title" id="filters-title">🔍 Filters &amp; Search</h2>
        <div class="controls">
          <label for="cropFilter" class="sr-only">Filter by crop</label>
          <select id="cropFilter" aria-label="Filter by crop">
            <option value="">All Crops</option>
          </select>

          <label for="marketFilter" class="sr-only">Filter by market</label>
          <select id="marketFilter" aria-label="Filter by market">
            <option value="">All Markets</option>
          </select>

          <label for="currencySelect" class="sr-only">Display currency</label>
          <select id="currencySelect" aria-label="Display currency">
            <option value="INR">India — Indian Rupee (₹)</option>
            <option value="USD">America — US Dollar ($)</option>
            <option value="LKR">Sri Lanka — Sri Lankan Rupee (LKR)</option>
          </select>

          <label for="searchInput" class="sr-only">Search prices</label>
          <input type="text" id="searchInput" placeholder="Search crop or market…" aria-label="Search" />

          <button id="loadBtn" type="button">Load Prices</button>
          <button id="downloadBtn" type="button" class="btn-secondary" disabled>Download CSV</button>
        </div>
        <p class="filter-hint" id="filterHint" role="status" aria-live="polite"></p>
      </section>

      <!-- Prices table card -->
      <section class="card" aria-labelledby="prices-title">
        <h2 class="card-title" id="prices-title">💰 Price Comparison</h2>
        <div class="table-wrapper">
          <table id="priceTable" aria-label="Price comparison table">
            <thead>
              <tr>
                <th scope="col">Crop</th>
                <th scope="col">Market</th>
                <th scope="col">Min (<span id="currencyLabel">₹</span>)</th>
                <th scope="col">Max (<span id="currencyLabelMax">₹</span>)</th>
                <th scope="col">Modal (<span id="currencyLabelModal">₹</span>)</th>
              </tr>
            </thead>
            <tbody id="priceBody">
              <tr class="skeleton-row">
                <td><span class="skeleton"></span></td>
                <td><span class="skeleton" style="width:60%"></span></td>
                <td><span class="skeleton" style="width:40%"></span></td>
                <td><span class="skeleton" style="width:40%"></span></td>
                <td><span class="skeleton" style="width:40%"></span></td>
              </tr>
              <tr class="skeleton-row">
                <td><span class="skeleton" style="width:55%"></span></td>
                <td><span class="skeleton" style="width:70%"></span></td>
                <td><span class="skeleton" style="width:40%"></span></td>
                <td><span class="skeleton" style="width:40%"></span></td>
                <td><span class="skeleton" style="width:40%"></span></td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>

      <!-- Chart card -->
      <section class="card" id="chartCard" aria-labelledby="chart-title">
        <h2 class="card-title" id="chart-title">📊 Price Chart</h2>
        <div id="chartPlaceholder" class="empty-state">
          <div class="empty-state-icon">📊</div>
          <p>Load prices to see the chart.<br><small>Use the <strong>Load Prices</strong> button above.</small></p>
        </div>
        <canvas id="priceChart" role="img" aria-label="Bar chart of prices" style="display:none"></canvas>
      </section>

      <!-- Alert card -->
      <section class="card" aria-labelledby="alert-title">
        <h2 class="card-title" id="alert-title">🔔 Price Alert</h2>
        <div class="alert-form">
          <label for="alertCrop" class="sr-only">Crop for alert</label>
          <select id="alertCrop" aria-label="Select crop for alert">
            <option value="">Select crop…</option>
          </select>
          <label for="alertPrice" class="sr-only">Alert price</label>
          <input type="number" id="alertPrice" placeholder="Alert price" min="0" step="0.01" aria-label="Alert threshold price" />
          <button id="setAlertBtn" type="button">Set Alert</button>
        </div>
        <p id="alertMessage" role="status" aria-live="polite"></p>
      </section>

    </div>
  </main>

  <ChatWidget />

  </Layout>

  <!-- Load Chart.js from CDN to avoid bundling issues during build -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.1/dist/chart.umd.min.js"></script>

  <script>

// ── Chart.js CDN type shim ───────────────────────────────
declare const Chart: any;

// ── Price record type ────────────────────────────────────
interface PriceRecord {
  commodity?: string; crop?: string; market?: string;
  min_price?: number|string; minPrice?: number|string;
  max_price?: number|string; maxPrice?: number|string;
  modal_price?: number|string; modalPrice?: number|string; price?: number|string;
}

// ── Helpers & Currency ───────────────────────────────────
const currencyLocales: Record<string, string> = { INR: 'en-IN', USD: 'en-US', LKR: 'en-LK' };
const currencySymbols: Record<string, string> = { INR: '₹', USD: '$', LKR: 'LKR' };
let selectedCurrency: string = (localStorage.getItem('displayCurrency') || 'INR');
let rates: Record<string, number> = { INR: 1 };
let ratesUpdatedAt: string | null = null;

const fmt = (n: number | string): string =>
  new Intl.NumberFormat(currencyLocales[selectedCurrency] || 'en-IN', {
    style: 'currency', currency: selectedCurrency, maximumFractionDigits: 2
  }).format(Number(n) || 0);

function showToast(msg: string, type: 'info' | 'success' | 'error' = 'info', duration = 3500): void {
  const container = document.getElementById('toastContainer');
  if (!container) return;
  const t = document.createElement('div');
  t.className = `toast ${type}`;
  t.setAttribute('role', type === 'error' ? 'alert' : 'status');
  t.textContent = msg;
  container.appendChild(t);
  setTimeout(() => {
    t.classList.add('removing');
    t.addEventListener('animationend', () => t.remove(), { once: true });
  }, duration);
}

// ── State ────────────────────────────────────────────────
let allData: PriceRecord[] = [];
let chart: any = null;

// ── DOM refs (cast to specific element types) ─────────────
const cropFilter     = document.getElementById('cropFilter')     as HTMLSelectElement | null;
const marketFilter   = document.getElementById('marketFilter')   as HTMLSelectElement | null;
const searchInput    = document.getElementById('searchInput')    as HTMLInputElement  | null;
const priceBody      = document.getElementById('priceBody')      as HTMLElement       | null;
const filterHint     = document.getElementById('filterHint')     as HTMLElement       | null;
const downloadBtn    = document.getElementById('downloadBtn')    as HTMLButtonElement | null;
const loadBtn        = document.getElementById('loadBtn')        as HTMLButtonElement | null;
const alertCrop      = document.getElementById('alertCrop')      as HTMLSelectElement | null;
const alertPrice     = document.getElementById('alertPrice')     as HTMLInputElement  | null;
const setAlertBtn    = document.getElementById('setAlertBtn')    as HTMLButtonElement | null;
const alertMsg       = document.getElementById('alertMessage')   as HTMLElement       | null;
const currencySelect = document.getElementById('currencySelect') as HTMLSelectElement | null;
const currencyLabelEl      = document.getElementById('currencyLabel')      as HTMLElement | null;
const currencyLabelElMax   = document.getElementById('currencyLabelMax')   as HTMLElement | null;
const currencyLabelElModal = document.getElementById('currencyLabelModal') as HTMLElement | null;

function convert(inrValue: number | string): number {
  const v = Number(inrValue) || 0;
  const r = rates[selectedCurrency] ?? 1;
  return v * r;
}

async function loadRates(): Promise<void> {
  try {
    const syms = Object.keys(currencyLocales).join(',');
    const res = await fetch(`https://api.exchangerate.host/latest?base=INR&symbols=${syms}`);
    if (!res.ok) throw new Error('rate fetch failed');
    const j = await res.json();
    rates = Object.assign({ INR: 1 }, j.rates || {});
    ratesUpdatedAt = j.date || new Date().toISOString();
    setCurrencyLabels();
  } catch (e) {
    showToast('Could not fetch live exchange rates — using cached values.', 'error');
  }
}

function setCurrencyLabels(): void {
  const sym = currencySymbols[selectedCurrency] || selectedCurrency;
  if (currencyLabelEl)      currencyLabelEl.textContent      = sym;
  if (currencyLabelElMax)   currencyLabelElMax.textContent   = sym;
  if (currencyLabelElModal) currencyLabelElModal.textContent = sym;
  if (alertPrice)    alertPrice.placeholder    = `Alert price (${selectedCurrency})`;
  if (currencySelect) currencySelect.value     = selectedCurrency;
}

// ── Load prices ──────────────────────────────────────────
async function loadPrices(): Promise<void> {
  if (loadBtn) { loadBtn.disabled = true; loadBtn.textContent = 'Loading…'; }
  try {
    let res: Response | null = null;
    try { res = await fetch('/api/prices'); } catch { res = null; }
    if (!res || !res.ok) res = await fetch('/prices.json');
    if (!res || !res.ok) throw new Error(`HTTP ${res ? res.status : 'no response'}`);
    const data = await res.json();

    if (Array.isArray(data)) {
      allData = data as PriceRecord[];
    } else if (Array.isArray(data.prices)) {
      allData = data.prices as PriceRecord[];
    } else if (Array.isArray(data.markets)) {
      const recs: PriceRecord[] = [];
      (data.markets as any[]).forEach((m: any) => {
        const mName: string = m.name || m.market || 'Unknown';
        const commodities: Record<string, any> = m.commodities || {};
        Object.keys(commodities).forEach(c => {
          const info = commodities[c] || {};
          recs.push({
            commodity: c, market: mName,
            min_price:   info.low  ?? info.min   ?? 0,
            max_price:   info.high ?? info.max   ?? 0,
            modal_price: info.price ?? info.modal ?? 0,
          });
        });
      });
      allData = recs;
    } else if (Array.isArray(data.data)) {
      allData = data.data as PriceRecord[];
    } else {
      allData = [];
    }

    if (!allData.length) {
      showToast('No price data found.', 'info');
      if (priceBody) priceBody.innerHTML = `<tr><td colspan="5"><div class="empty-state" role="status" aria-live="polite"><div class="empty-state-icon">🌱</div><p>No data available yet.</p><p><button id="retryLoadBtn" type="button" class="btn-secondary">Retry loading prices</button></p></div></td></tr>`;
      setTimeout(() => {
        const r = document.getElementById('retryLoadBtn');
        if (r) r.addEventListener('click', () => { if (loadBtn) loadBtn.click(); });
      }, 120);
      return;
    }

    populateFilters(allData);
    displayPrices(allData);
    updateChart(allData);
    updateStats(allData);
    if (downloadBtn) downloadBtn.disabled = false;
    showToast(`Loaded ${allData.length} price records.`, 'success');
  } catch (err) {
    if (priceBody) priceBody.innerHTML = `<tr><td colspan="5"><div class="empty-state"><div class="empty-state-icon">⚠️</div><p><strong>Could not load prices.</strong><br>Check your connection and try again.</p></div></td></tr>`;
    showToast('Failed to load prices. Please try again.', 'error');
  } finally {
    if (loadBtn) { loadBtn.disabled = false; loadBtn.textContent = 'Load Prices'; }
  }
}

// ── Populate filter selects ──────────────────────────────
function populateFilters(data: PriceRecord[]): void {
  const crops   = [...new Set(data.map(d => d.commodity || d.crop))].filter(Boolean).sort() as string[];
  const markets = [...new Set(data.map(d => d.market))].filter(Boolean).sort() as string[];

  function setOptions(sel: HTMLSelectElement | null, vals: string[], label: string): void {
    if (!sel) return;
    const cur = sel.value;
    sel.innerHTML = `<option value="">${label}</option>`;
    vals.forEach(v => {
      const o = document.createElement('option'); o.value = o.textContent = v; sel.appendChild(o);
    });
    if (vals.includes(cur)) sel.value = cur;
  }

  setOptions(cropFilter, crops, 'All Crops');
  setOptions(marketFilter, markets, 'All Markets');
  setOptions(alertCrop, crops, 'Select crop…');
}

// ── Display table ────────────────────────────────────────
function displayPrices(data: PriceRecord[]): void {
  const crop   = (cropFilter?.value   || '').toLowerCase();
  const market = (marketFilter?.value || '').toLowerCase();
  const search = (searchInput?.value  || '').toLowerCase();

  const filtered = data.filter((d: PriceRecord) => {
    const c = (d.commodity || d.crop || '').toLowerCase();
    const m = (d.market || '').toLowerCase();
    return (!crop   || c === crop)
        && (!market || m === market)
        && (!search || c.includes(search) || m.includes(search));
  });

  if (filterHint) filterHint.textContent = (search || crop || market)
    ? `Showing ${filtered.length} of ${data.length} records` : '';

  if (!filtered.length) {
    if (priceBody) priceBody.innerHTML = `<tr><td colspan="5"><div class="empty-state" role="status" aria-live="polite"><div class="empty-state-icon">🔍</div><p>No results match your filters.<br><small>Try changing or clearing the filters above.</small></p><p><button type="button" class="btn-secondary" id="clearFiltersBtn">Clear filters</button></p></div></td></tr>`;
    setTimeout(() => {
      const btn = document.getElementById('clearFiltersBtn');
      if (btn) btn.addEventListener('click', () => {
        if (cropFilter)   cropFilter.value   = '';
        if (marketFilter) marketFilter.value = '';
        if (searchInput)  searchInput.value  = '';
        displayPrices(allData);
      });
    }, 50);
    updateChart([]);
    return;
  }

  const basePrices = filtered.map((d: PriceRecord) => Number(d.modal_price || d.modalPrice || d.price || 0));
  const prices     = basePrices.map((v: number) => convert(v));
  const maxP = Math.max(...prices);
  const minP = Math.min(...prices);

  if (priceBody) {
    priceBody.innerHTML = filtered.map((d: PriceRecord) => {
      const name = d.commodity || d.crop || 'Unknown';
      const mkt  = d.market   || '—';
      const lo   = Number(d.min_price   || d.minPrice   || 0);
      const hi   = Number(d.max_price   || d.maxPrice   || 0);
      const mod  = Number(d.modal_price || d.modalPrice || d.price || 0);
      const loC  = convert(lo);
      const hiC  = convert(hi);
      const modC = convert(mod);
      const cls  = modC === maxP ? 'highest' : modC === minP ? 'lowest' : '';
      return `<tr class="${cls}">
        <td>${name}</td><td>${mkt}</td>
        <td>${fmt(loC)}</td><td>${fmt(hiC)}</td><td>${fmt(modC)}</td>
      </tr>`;
    }).join('');
  }

  updateChart(filtered);
}

// ── Update chart ─────────────────────────────────────────
function updateChart(data: PriceRecord[]): void {
  const canvas      = document.getElementById('priceChart')      as HTMLCanvasElement | null;
  const placeholder = document.getElementById('chartPlaceholder') as HTMLElement      | null;

  if (chart) { try { chart.destroy(); } catch { /* ignore */ } chart = null; }

  if (!data || !data.length) {
    if (canvas)      canvas.style.display      = 'none';
    if (placeholder) placeholder.style.display = '';
    return;
  }

  const basePrices = data.map((d: PriceRecord) => Number(d.modal_price || d.modalPrice || d.price || 0));
  const prices     = basePrices.map((v: number) => convert(v));
  const maxP = Math.max(...prices);
  const minP = Math.min(...prices);

  if (canvas)      canvas.style.display      = '';
  if (placeholder) placeholder.style.display = 'none';

  chart = new Chart(canvas, {
    type: 'bar',
    data: {
      labels: data.map((d: PriceRecord) => `${d.commodity || d.crop} (${d.market})`),
      datasets: [{
        label: `Modal Price (${selectedCurrency})`,
        data: prices,
        backgroundColor: prices.map((p: number) =>
          p === maxP ? 'rgba(27,94,32,0.85)' :
          p === minP ? 'rgba(198,40,40,0.75)' : 'rgba(67,160,71,0.65)'
        ),
        borderColor: prices.map((p: number) =>
          p === maxP ? 'rgba(27,94,32,1)' :
          p === minP ? 'rgba(198,40,40,1)' : 'rgba(46,125,50,1)'
        ),
        borderWidth: 1.5, borderRadius: 5,
      }],
    },
    options: {
      responsive: true, maintainAspectRatio: true,
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: (ctx: any) => `${fmt(ctx.parsed?.y ?? 0)}` } },
      },
      scales: {
        y: { beginAtZero: true, ticks: { callback: (v: any) => `${fmt(v)}` } },
        x: { ticks: { maxRotation: 45, font: { size: 11 } } },
      },
    },
  });
}

// ── Stats bar ────────────────────────────────────────────
function updateStats(data: PriceRecord[]): void {
  const bar     = document.getElementById('statsBar');
  const prices  = data.map((d: PriceRecord) => Number(d.modal_price || d.modalPrice || d.price || 0)).filter(Boolean);
  const crops   = new Set(data.map((d: PriceRecord) => d.commodity || d.crop)).size;
  const markets = new Set(data.map((d: PriceRecord) => d.market)).size;
  const baseAvg = prices.length ? prices.reduce((a: number, b: number) => a + b, 0) / prices.length : 0;
  const hi = prices.length ? Math.max(...prices) : 0;
  const lo = prices.length ? Math.min(...prices) : 0;

  const statCrops   = document.getElementById('statCrops');
  const statMarkets = document.getElementById('statMarkets');
  const statAvg     = document.getElementById('statAvg');
  const statHigh    = document.getElementById('statHigh');
  const statLow     = document.getElementById('statLow');

  if (statCrops)   statCrops.textContent   = String(crops);
  if (statMarkets) statMarkets.textContent = String(markets);
  if (statAvg)     statAvg.textContent     = fmt(convert(baseAvg));
  if (statHigh)    statHigh.textContent    = fmt(convert(hi));
  if (statLow)     statLow.textContent     = fmt(convert(lo));
  if (bar)         bar.removeAttribute('hidden');
}

// ── Download CSV ─────────────────────────────────────────
function downloadCSV(): void {
  if (!allData.length) return;
  const header = `Crop,Market,Min Price (${selectedCurrency}),Max Price (${selectedCurrency}),Modal Price (${selectedCurrency})`;
  const rows = allData.map((d: PriceRecord) => {
    const lo  = Number(d.min_price   || d.minPrice   || 0);
    const hi  = Number(d.max_price   || d.maxPrice   || 0);
    const mod = Number(d.modal_price || d.modalPrice || d.price || 0);
    return [d.commodity || d.crop, d.market, convert(lo).toFixed(2), convert(hi).toFixed(2), convert(mod).toFixed(2)]
      .map(v => `"${String(v ?? '').replace(/"/g, '""')}"`)
      .join(',');
  });
  const csv = [header, ...rows].join('\n');
  const url = URL.createObjectURL(new Blob([csv], { type: 'text/csv' }));
  const a = document.createElement('a');
  a.href = url; a.download = 'farm-prices.csv'; a.click();
  setTimeout(() => URL.revokeObjectURL(url), 3000);
  showToast('CSV downloaded!', 'success');
}

// ── Price alert ──────────────────────────────────────────
function setAlert(): void {
  const crop  = alertCrop?.value.trim()     || '';
  const price = parseFloat(alertPrice?.value || '0');
  if (!crop)                     { showToast('Please select a crop first.', 'error'); return; }
  if (isNaN(price) || price <= 0){ showToast(`Enter a valid price above ${fmt(0)}`, 'error'); return; }
  if (alertMsg) alertMsg.textContent = `✅ Alert set: notify when ${crop} ≥ ${fmt(price)}.`;
  showToast(`Alert set for ${crop} at ${fmt(price)}`, 'success');
}

// ── Event listeners ──────────────────────────────────────
if (loadBtn)      loadBtn.addEventListener('click', loadPrices);
if (downloadBtn)  downloadBtn.addEventListener('click', downloadCSV);
if (setAlertBtn)  setAlertBtn.addEventListener('click', setAlert);
if (cropFilter)   cropFilter.addEventListener('change', () => displayPrices(allData));
if (marketFilter) marketFilter.addEventListener('change', () => displayPrices(allData));
if (searchInput)  searchInput.addEventListener('input', () => displayPrices(allData));
if (currencySelect) {
  currencySelect.addEventListener('change', async () => {
    selectedCurrency = currencySelect.value || 'INR';
    localStorage.setItem('displayCurrency', selectedCurrency);
    await loadRates();
    setCurrencyLabels();
    displayPrices(allData);
    updateStats(allData);
    updateChart(allData);
  });
}

document.addEventListener('DOMContentLoaded', async () => {
  await loadRates();
  setCurrencyLabels();
  loadPrices();
  setInterval(loadRates, 300_000);
});

// ── PWA install prompt ───────────────────────────────────
let deferredPrompt: any = null;
const installBtn = document.getElementById('installBtn') as HTMLButtonElement | null;
window.addEventListener('beforeinstallprompt', (e: Event) => {
  e.preventDefault();
  deferredPrompt = e;
  if (installBtn) installBtn.removeAttribute('hidden');
});
if (installBtn) {
  installBtn.addEventListener('click', async () => {
    if (!deferredPrompt) return;
    deferredPrompt.prompt();
    const { outcome } = await deferredPrompt.userChoice;
    if (outcome === 'accepted') showToast('App installed!', 'success');
    deferredPrompt = null;
    installBtn.setAttribute('hidden', '');
  });
}
window.addEventListener('appinstalled', () => {
  showToast('App installed successfully!', 'success');
  if (installBtn) installBtn.setAttribute('hidden', '');
});
</script>
