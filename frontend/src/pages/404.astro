---
import Layout from '../layouts/Layout.astro';
import BotSvg from '../components/BotSvg.astro';
import ChatWidget from '../components/ChatWidget.astro';
---
<Layout title="Page Not Found — Farm Market Prices" page="404">
  <div class="offline-bg">
    <video id="bg-video" autoplay muted loop playsinline preload="auto" aria-hidden="true">
      <source src="/assets/videos/error404.mp4" type="video/mp4" />
    </video>
    <div class="bg-overlay" aria-hidden="true"></div>
  </div>

  <style>
    .offline-bg video { position: fixed; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: -2; filter: brightness(.45) saturate(.85); }
    .offline-bg .bg-overlay { position: fixed; inset: 0; background: rgba(4,18,8,0.32); z-index: -1; }
    main#main-content, header { position: relative; z-index: 1; }
    .page-wrapper { min-height: 80vh; display:flex; align-items:center; justify-content:center; }
    .error-card {
      max-width: 460px; width: 100%;
      background: rgba(255,255,255,0.97);
      border: 1px solid var(--border-soft);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-lg);
      padding: 36px 32px;
      text-align: center;
    }
    .error-card h2 { font-size: 1.7rem; color: #bf360c; margin-bottom: 10px; font-weight: 800; letter-spacing: -.4px; }
    .error-card p { color: var(--muted); font-size: .95rem; line-height: 1.75; margin-bottom: 28px; }
    .error-back-btn {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 11px 30px;
      background: linear-gradient(135deg, #f57c00, #e65100);
      color: #fff; border-radius: var(--radius-pill);
      text-decoration: none; font-weight: 700; font-size: .92rem;
      box-shadow: 0 4px 14px rgba(230,81,0,.32);
      transition: filter .18s ease, transform .18s ease, box-shadow .18s ease;
      letter-spacing: .01em;
    }
    .error-back-btn:hover { filter: brightness(1.08); transform: translateY(-2px); box-shadow: 0 8px 22px rgba(230,81,0,.42); }
  </style>

  <header style="background:linear-gradient(145deg,#bf360c 0%,#e65100 40%,#f57c00 80%,#f9a825 100%)">
    <h1>🌾 Farm Market Prices</h1>
  </header>
  <main id="main-content">
    <div class="page-wrapper" style="align-items:center; text-align:center; padding-top:60px">
      <div class="error-card">
        <div style="position:relative; display:inline-block; margin-bottom:16px">
          <BotSvg idPrefix="bot-404" size={92} mood="surprised" bodyColor="#ffb300" antennaColor="#ffb300" mouthColor="#ef6c00" />
          <span style="position:absolute; top:-6px; right:-10px; background:linear-gradient(135deg,#ef5350,#b71c1c); color:#fff; border-radius:50%; width:30px; height:30px; font-size:.85rem; font-weight:800; display:flex; align-items:center; justify-content:center; box-shadow:0 3px 10px rgba(0,0,0,.25); border:2.5px solid #fff">?</span>
        </div>
        <h2>Page Not Found</h2>
        <p>
          Oops! The page you're looking for has wandered off into the fields.<br>
          Let's get you back to safety.
        </p>
        <a href="/" class="error-back-btn" aria-label="Back to homepage">
          🌾 Back to Home
        </a>
      </div>
    </div>
  </main>

  <ChatWidget />
</Layout>

<script>
// Eye tracking for 404 bot
(function() {
  const pupilL = document.getElementById('bot-404-pupil-l');
  const pupilR = document.getElementById('bot-404-pupil-r');
  const glintL = document.getElementById('bot-404-glint-l');
  const glintR = document.getElementById('bot-404-glint-r');
  if (!pupilL) return;
  const BASE = { lx:23, ly:35, rx:41, ry:35, glx:24.5, gly:33, grx:42.5, gry:33 };
  const maxR = 2.2;
  window.addEventListener('mousemove', (e) => {
    const svg = pupilL.closest('svg'); if (!svg) return;
    const rect = svg.getBoundingClientRect();
    const angle = Math.atan2(e.clientY - (rect.top + rect.height/2), e.clientX - (rect.left + rect.width/2));
    const cos = Math.cos(angle), sin = Math.sin(angle);
    pupilL.setAttribute('cx', String(BASE.lx + cos * maxR));
    pupilL.setAttribute('cy', String(BASE.ly + sin * maxR));
    pupilR!.setAttribute('cx', String(BASE.rx + cos * maxR));
    pupilR!.setAttribute('cy', String(BASE.ry + sin * maxR));
    glintL!.setAttribute('cx', String(BASE.glx + cos * maxR));
    glintL!.setAttribute('cy', String(BASE.gly + sin * maxR));
    glintR!.setAttribute('cx', String(BASE.grx + cos * maxR));
    glintR!.setAttribute('cy', String(BASE.gry + sin * maxR));
  }, { passive: true });
})();
// Focus primary action for keyboard users
document.addEventListener('DOMContentLoaded', () => {
  const action = document.querySelector('a[aria-label="Back to homepage"]') as HTMLElement | null;
  if (action) action.focus();
});
</script>
