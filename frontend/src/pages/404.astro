---
import Layout from '../layouts/Layout.astro';
import BotSvg from '../components/BotSvg.astro';
---
<Layout title="Page Not Found — Farm Market Prices" page="404">
  <div class="offline-bg">
    <video id="bg-video" autoplay muted loop playsinline preload="auto" poster="/assets/videos/agriculture-environment.mp4">
      <source src="/assets/videos/agriculture-environment.mp4" type="video/mp4" />
    </video>
    <div class="bg-overlay" aria-hidden="true"></div>
  </div>

  <style>
    .offline-bg video { position: fixed; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: -2; }
    .offline-bg .bg-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.28); z-index: -1; }
    main#main-content, header { position: relative; z-index: 1; }
    .page-wrapper { min-height: 80vh; display:flex; align-items:center; justify-content:center; }
  </style>

  <header>
    <h1>🌾 Farm Market Prices</h1>
  </header>
  <main id="main-content">
    <div class="page-wrapper" style="align-items:center; text-align:center; padding-top:60px">
      <div class="card" style="max-width:460px; width:100%">
        <div style="position:relative; display:inline-block; margin-bottom:12px">
          <BotSvg idPrefix="bot-404" size={90} />
          <span style="position:absolute; top:-6px; right:-10px; background:#ef5350; color:#fff; border-radius:50%; width:28px; height:28px; font-size:.85rem; font-weight:700; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 8px rgba(0,0,0,.2)">?</span>
        </div>
        <h2 style="font-size:1.6rem; color:#1b5e20; margin-bottom:8px">Page Not Found</h2>
        <p style="color:#607060; font-size:.95rem; line-height:1.7; margin-bottom:24px">
          Oops! The page you're looking for has wandered off into the fields.<br>
          Let's get you back to safety.
        </p>
        <a href="/" style="display:inline-block; padding:10px 28px; background:#2e7d32; color:#fff; border-radius:8px; text-decoration:none; font-weight:600; font-size:.93rem">
          🌾 Back to Home
        </a>
      </div>
    </div>
  </main>
</Layout>

<script>
// Eye tracking for 404 bot
(function() {
  const pupilL = document.getElementById('bot-404-pupil-l');
  const pupilR = document.getElementById('bot-404-pupil-r');
  const glintL = document.getElementById('bot-404-glint-l');
  const glintR = document.getElementById('bot-404-glint-r');
  if (!pupilL) return;
  const BASE = { lx:23, ly:35, rx:41, ry:35, glx:24.5, gly:33, grx:42.5, gry:33 };
  const maxR = 2.2;
  window.addEventListener('mousemove', (e) => {
    const svg = pupilL.closest('svg'); if (!svg) return;
    const rect = svg.getBoundingClientRect();
    const angle = Math.atan2(e.clientY - (rect.top + rect.height/2), e.clientX - (rect.left + rect.width/2));
    const cos = Math.cos(angle), sin = Math.sin(angle);
    pupilL.setAttribute('cx', String(BASE.lx + cos * maxR));
    pupilL.setAttribute('cy', String(BASE.ly + sin * maxR));
    pupilR!.setAttribute('cx', String(BASE.rx + cos * maxR));
    pupilR!.setAttribute('cy', String(BASE.ry + sin * maxR));
    glintL!.setAttribute('cx', String(BASE.glx + cos * maxR));
    glintL!.setAttribute('cy', String(BASE.gly + sin * maxR));
    glintR!.setAttribute('cx', String(BASE.grx + cos * maxR));
    glintR!.setAttribute('cy', String(BASE.gry + sin * maxR));
  }, { passive: true });
})();
</script>
