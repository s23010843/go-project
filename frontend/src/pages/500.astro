---
import Layout from '../layouts/Layout.astro';
import BotSvg from '../components/BotSvg.astro';
---
<Layout title="Server Error — Farm Market Prices" page="500">
  <div class="offline-bg">
    <video id="bg-video" muted loop playsinline preload="auto" poster="/assets/videos/agriculture-environment.mp4" aria-hidden="true">
      <source src="/assets/videos/agriculture-environment.mp4" type="video/mp4" />
    </video>
    <div class="bg-overlay" aria-hidden="true"></div>
  </div>

  <style>
    .offline-bg video { position: fixed; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: -2; filter: brightness(.42) saturate(.80); }
    .offline-bg .bg-overlay { position: fixed; inset: 0; background: rgba(40,4,4,0.32); z-index: -1; }
    main#main-content, header { position: relative; z-index: 1; }
    .page-wrapper { min-height: 80vh; display:flex; align-items:center; justify-content:center; }
    .error-card {
      max-width: 460px; width: 100%;
      background: rgba(255,255,255,0.97);
      border: 1px solid var(--border-soft);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-lg);
      padding: 36px 32px;
      text-align: center;
    }
    .error-card h2 { font-size: 1.7rem; color: #b71c1c; margin-bottom: 10px; font-weight: 800; letter-spacing: -.4px; }
    .error-card p { color: var(--muted); font-size: .95rem; line-height: 1.75; margin-bottom: 28px; }
    .err-btn-primary {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 11px 26px;
      background: linear-gradient(135deg, #e53935, #b71c1c);
      color: #fff; border: none; border-radius: var(--radius-pill);
      font-weight: 700; font-size: .92rem; font-family: inherit; cursor: pointer;
      box-shadow: 0 4px 14px rgba(183,28,28,.30);
      transition: filter .18s ease, transform .18s ease, box-shadow .18s ease;
    }
    .err-btn-primary:hover { filter: brightness(1.08); transform: translateY(-2px); box-shadow: 0 8px 20px rgba(183,28,28,.36); }
    .err-btn-secondary {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 11px 26px;
      background: var(--surface); color: var(--green-800);
      border: 1.5px solid var(--border); border-radius: var(--radius-pill);
      text-decoration: none; font-weight: 600; font-size: .92rem;
      transition: background .18s ease, border-color .18s ease;
    }
    .err-btn-secondary:hover { background: var(--green-50); border-color: var(--green-400); }
    .action-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  </style>

  <header style="background:linear-gradient(135deg,#b71c1c 0%,#c62828 60%,#ef5350 100%)">
    <h1>🌾 Farm Market Prices</h1>
  </header>
  <main id="main-content">
    <div class="page-wrapper" style="align-items:center; text-align:center; padding-top:60px">
      <div class="error-card">
        <div style="position:relative; display:inline-block; margin-bottom:16px">
          <BotSvg idPrefix="bot-500" size={92} mood="sad" bodyColor="#b71c1c" antennaColor="#c62828" mouthColor="#b71c1c" />
          <span style="position:absolute; top:-6px; right:-10px; background:linear-gradient(135deg,#ef5350,#b71c1c); color:#fff; border-radius:50%; width:30px; height:30px; font-size:.85rem; font-weight:800; display:flex; align-items:center; justify-content:center; box-shadow:0 3px 10px rgba(0,0,0,.25); border:2.5px solid #fff">!</span>
        </div>
        <h2>Something Went Wrong</h2>
        <p>
          Our server hit a bump in the road. Don't worry — our team has been notified.<br>
          Please try again in a moment.
        </p>
        <div class="action-row">
          <button type="button" id="tryAgain" aria-label="Try reloading the page" class="err-btn-primary">
            🔄 Try Again
          </button>
          <a href="/" class="err-btn-secondary" aria-label="Back to homepage">
            🌾 Back to Home
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
(function() {
  const pupilL = document.getElementById('bot-500-pupil-l');
  const pupilR = document.getElementById('bot-500-pupil-r');
  const glintL = document.getElementById('bot-500-glint-l');
  const glintR = document.getElementById('bot-500-glint-r');
  if (!pupilL) return;
  const BASE = { lx:23, ly:35, rx:41, ry:35, glx:24.5, gly:33, grx:42.5, gry:33 };
  const maxR = 2.2;
  window.addEventListener('mousemove', (e) => {
    const svg = pupilL.closest('svg'); if (!svg) return;
    const rect = svg.getBoundingClientRect();
    const angle = Math.atan2(e.clientY - (rect.top + rect.height/2), e.clientX - (rect.left + rect.width/2));
    const cos = Math.cos(angle), sin = Math.sin(angle);
    pupilL.setAttribute('cx', String(BASE.lx + cos * maxR));
    pupilL.setAttribute('cy', String(BASE.ly + sin * maxR));
    pupilR!.setAttribute('cx', String(BASE.rx + cos * maxR));
    pupilR!.setAttribute('cy', String(BASE.ry + sin * maxR));
    glintL!.setAttribute('cx', String(BASE.glx + cos * maxR));
    glintL!.setAttribute('cy', String(BASE.gly + sin * maxR));
    glintR!.setAttribute('cx', String(BASE.grx + cos * maxR));
    glintR!.setAttribute('cy', String(BASE.gry + sin * maxR));
  }, { passive: true });
})();

// Make retry button accessible and focus it
document.addEventListener('DOMContentLoaded', () => {
  const btn = document.getElementById('tryAgain');
  if (btn) {
    btn.addEventListener('click', () => window.location.reload());
    try { (btn as HTMLElement).focus(); } catch (e) {}
  }
});
</script>
