---
import Layout from '../layouts/Layout.astro';
import BotSvg from '../components/BotSvg.astro';
---
<Layout title="You're Offline — Farm Market Prices" page="offline">
  <div class="offline-bg">
    <video id="bg-video" muted loop playsinline preload="auto" poster="/assets/videos/agriculture-environment.mp4" aria-hidden="true">
      <source src="/assets/videos/agriculture-environment.mp4" type="video/mp4" />
    </video>
    <div class="bg-overlay" aria-hidden="true"></div>
  </div>

  <style>
    .offline-bg video { position: fixed; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: -2; filter: brightness(.44) saturate(.80); }
    .offline-bg .bg-overlay { position: fixed; inset: 0; background: rgba(4,12,24,0.30); z-index: -1; }
    main#main-content, header { position: relative; z-index: 1; }
    .page-wrapper { min-height: 80vh; display:flex; align-items:center; justify-content:center; }
    .error-card {
      max-width: 480px; width: 100%;
      background: rgba(255,255,255,0.97);
      border: 1px solid var(--border-soft);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-lg);
      padding: 36px 32px;
      text-align: center;
    }
    .error-card h2 { font-size: 1.65rem; color: var(--green-900); margin-bottom: 10px; font-weight: 800; letter-spacing: -.4px; }
    .error-card > p { color: var(--muted); font-size: .93rem; line-height: 1.75; margin-bottom: 20px; }
    .offline-checklist {
      background: var(--green-50); border: 1.5px solid var(--green-200);
      border-radius: var(--radius-lg); text-align: left;
      padding: 16px 20px; margin-bottom: 24px;
    }
    .offline-checklist p { font-weight: 700; color: var(--green-800); margin-bottom: 10px; font-size: .9rem; }
    .offline-checklist ul { color: var(--muted); font-size: .875rem; line-height: 2; list-style: none; padding: 0; }
    .err-btn-primary {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 11px 26px;
      background: linear-gradient(135deg, var(--green-600), var(--green-800));
      color: #fff; border: none; border-radius: var(--radius-pill);
      font-weight: 700; font-size: .92rem; font-family: inherit; cursor: pointer;
      box-shadow: 0 4px 14px rgba(30,90,35,.28);
      transition: filter .18s ease, transform .18s ease, box-shadow .18s ease;
    }
    .err-btn-primary:hover { filter: brightness(1.08); transform: translateY(-2px); box-shadow: 0 8px 20px rgba(30,90,35,.34); }
    .err-btn-secondary {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 11px 26px;
      background: var(--surface); color: var(--green-800);
      border: 1.5px solid var(--border); border-radius: var(--radius-pill);
      text-decoration: none; font-weight: 600; font-size: .92rem;
      transition: background .18s ease, border-color .18s ease;
    }
    .err-btn-secondary:hover { background: var(--green-50); border-color: var(--green-400); }
    .action-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  </style>

  <header>
    <h1>🌾 Farm Market Prices</h1>
  </header>
  <main id="main-content">
    <div class="page-wrapper" style="align-items:center; text-align:center; padding-top:60px">
      <div class="error-card">
        <div style="margin-bottom:16px">
          <BotSvg idPrefix="bot-offline" size={92} mood="neutral" bodyColor="#546e7a" panelColor="#eceff1" pupilColor="#263238" antennaColor="#90a4ae" mouthColor="#37474f" />
        </div>
        <h2>You're Offline</h2>
        <p>No internet connection detected. You can still access cached data.</p>

        <div class="offline-checklist">
          <p>✅ Available offline:</p>
          <ul>
            <li>✔ Previously loaded price data</li>
            <li>✔ Filter and search functionality</li>
            <li>✔ CSV download of cached data</li>
            <li>✔ FarmBot chat assistant</li>
          </ul>
        </div>

        <div class="action-row">
          <button id="retryBtn" type="button" aria-label="Retry loading the site" class="err-btn-primary">
            🔄 Try Again
          </button>
          <a href="/" class="err-btn-secondary" aria-label="Go to home page">
            🌾 Go Home
          </a>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
// Auto-reload when back online
window.addEventListener('online', () => {
  document.getElementById('retryBtn')!.textContent = '✅ Back online! Reloading…';
  setTimeout(() => window.location.reload(), 800);
});
const _retry = document.getElementById('retryBtn');
if (_retry) _retry.addEventListener('click', () => window.location.reload());

// Eye tracking
(function() {
  const pupilL = document.getElementById('bot-offline-pupil-l');
  const pupilR = document.getElementById('bot-offline-pupil-r');
  const glintL = document.getElementById('bot-offline-glint-l');
  const glintR = document.getElementById('bot-offline-glint-r');
  if (!pupilL) return;
  const BASE = { lx:23, ly:35, rx:41, ry:35, glx:24.5, gly:33, grx:42.5, gry:33 };
  const maxR = 2.2;
  window.addEventListener('mousemove', (e) => {
    const svg = pupilL.closest('svg'); if (!svg) return;
    const rect = svg.getBoundingClientRect();
    const angle = Math.atan2(e.clientY - (rect.top + rect.height/2), e.clientX - (rect.left + rect.width/2));
    const cos = Math.cos(angle), sin = Math.sin(angle);
    pupilL.setAttribute('cx', String(BASE.lx + cos * maxR));
    pupilL.setAttribute('cy', String(BASE.ly + sin * maxR));
    pupilR!.setAttribute('cx', String(BASE.rx + cos * maxR));
    pupilR!.setAttribute('cy', String(BASE.ry + sin * maxR));
    glintL!.setAttribute('cx', String(BASE.glx + cos * maxR));
    glintL!.setAttribute('cy', String(BASE.gly + sin * maxR));
    glintR!.setAttribute('cx', String(BASE.grx + cos * maxR));
    glintR!.setAttribute('cy', String(BASE.gry + sin * maxR));
  }, { passive: true });
})();
</script>

<script>
// Focus retry button for keyboard users
document.addEventListener('DOMContentLoaded', () => {
  const r = document.getElementById('retryBtn');
  if (r) try { (r as HTMLElement).focus(); } catch (e) {}
});
</script>
